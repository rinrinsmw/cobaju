# Local Phase 13 defaults. SQLite, uploads, and Chroma stay inside apps/backend.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
APP_ENVIRONMENT=development
FRONTEND_PORT=8443
DATABASE_URL=sqlite:///./cobaju.db
# Generate a private local value, for example: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-a-long-random-local-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
UPLOAD_DIRECTORY=./uploads
# OpenRouter models must support image input and structured outputs.
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_GUARDRAIL_MODEL=replace-with-a-low-cost-vision-model
OPENROUTER_VISION_MODEL=replace-with-a-vision-model
# Must be a text embedding model available through OpenRouter.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_CHAT_GUARDRAIL_MODEL=replace-with-a-low-cost-text-model
OPENROUTER_STYLIST_MODEL=replace-with-a-tool-calling-text-model
# OPENROUTER_EVALUATOR_MODEL remains a backward-compatible fallback.
OPENROUTER_STYLE_CRITIC_MODEL=replace-with-a-structured-output-text-model
OPENROUTER_EVALUATOR_MODEL=replace-with-a-structured-output-text-model
OPENROUTER_TIMEOUT_SECONDS=60
GUARDRAIL_TEMPERATURE=0.0
VISION_TEMPERATURE=0.1
CHAT_GUARDRAIL_TEMPERATURE=0.0
STYLIST_TEMPERATURE=0.5
STYLIST_REPAIR_TEMPERATURE=0.1
EVALUATOR_TEMPERATURE=0.0
STYLE_CRITIC_TEMPERATURE=0.0
STYLIST_MAX_TURNS=8
STYLIST_MAX_TOOL_CALLS=8
CHAT_GUARDRAIL_PROMPT_VERSION=chat-guardrail-v1
STYLIST_PROMPT_VERSION=stylist-v3
STYLIST_REPAIR_PROMPT_VERSION=stylist-repair-v1
EVALUATOR_PROMPT_VERSION=outfit-evaluator-v1
STYLE_CRITIC_PROMPT_VERSION=style-critic-v1
# Leave disabled for local development unless Langfuse credentials are set.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Celery sends clothing-analysis jobs through Redis and retries AI failures twice.
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_TASK_MAX_RETRIES=2
CELERY_TASK_RETRY_DELAY_SECONDS=5
# Persistent semantic wardrobe index and default maximum retrieval count.
CHROMA_DIRECTORY=./chroma
CHROMA_COLLECTION_NAME=wardrobe_items
WARDROBE_SEARCH_LIMIT=5
# Stylist retrieval returns at most this many compact items per category.
STYLING_CANDIDATES_PER_CATEGORY=3
