# Local Phase 2 defaults. SQLite stores data in apps/backend/cobaju.db.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=8443
DATABASE_URL=sqlite:///./cobaju.db
# Generate a private local value, for example: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-a-long-random-local-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
